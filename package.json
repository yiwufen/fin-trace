{
  "name": "fin-trace",
  "version": "1.0.0",
  "description": "Multi-hop relationship reasoning agent for financial knowledge graphs",
  "main": "dist/index.js",
  "bin": {
    "fin-trace": "./dist/index.js"
  },
  "files": [
    "dist/",
    "web/dist/",
    "config.example.json",
    "README.md"
  ],
  "workspaces": ["web"],
  "scripts": {
    "build": "tsc && npm run build -w web",
    "dev": "npm run build -w web && tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["fin-trace", "knowledge-graph", "mcp", "financial-analysis"],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openai": "^6.42.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4"
  }
}
