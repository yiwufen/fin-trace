# 依赖目录（构建阶段会重新 npm ci）
node_modules/
web/node_modules/

# 构建产物（构建阶段会重新生成）
dist/
web/dist/
**/*.tsbuildinfo

# 运行时数据（通过 volume 挂载，绝不进镜像）
data/
config.json

# 版本控制与编辑器
.git/
.gitignore
.claude/
.vscode/
.idea/

# 日志与临时文件
*.log
e2e-*.json
e2e-*.log
probe-*.json
.env

# 文档（不影响运行）
design-docs/
docs/
README.md
AGENTS.md
CLAUDE.md
